# Copy to `.env` and fill in real values. Do NOT commit the real .env.
# Every value here maps to a CLI flag in api/src/main.rs (clap `env`).

# --- Image (used by docker-compose.yaml) ---
# Full registry path + tag of the pre-built API image.
API_IMAGE=

# Host directory containing the tree_*.json files, mounted read-only into
# the container at /data/merkle-trees.
MERKLE_TREE_HOST_DIR=/opt/dfx/merkle-trees

# --- Required app config ---
# Solana RPC + WS endpoints (usually include a provider API key — keep secret).
RPC_URL=https://api.devnet.solana.com
WS_URL=wss://api.devnet.solana.com

# Token mint being distributed.
MINT=dfxKL8VLUjLMCnFiJ57ZjrjGDiDMLRX8tHmg8biUV39

# Distributor program ID (mainnet/devnet as appropriate).
PROGRAM_ID=AtXLVASdFhmdq2KZxzhVFonmNXL76dTTsEABXySEHgLh

# --- Optional: basic auth (set BOTH to protect data routes; "/" stays open) ---
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=change-me

# --- Optional: unvested/vested accounts CSV (mount it into the container too) ---
# UNVESTED_ACCOUNTS_PATH=/data/merkle-trees/unvested.csv
# UNVESTED_ACCOUNTS_DECIMALS=6

# --- Optional: fallback distributor config when none is found on-chain ---
# DEFAULT_START_TS=0
# DEFAULT_END_TS=3133657200
# DEFAULT_MINT=11111111111111111111111111111111
# START_AMOUNT_PCT=50

# --- Logging ---
RUST_LOG=info
